    <model name="bus_1">
      <pose>-46.000 46.000 0.28 0 0 0.0000</pose>
      <link name="base_link">
        <inertial>
          <mass>12</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="body_collision">
          <pose>0 0 0.975 0 0 0</pose>
          <geometry><box><size>3.8 1.35 1.25</size></box></geometry>
        </collision>
        <visual name="body_visual">
          <pose>0 0 0.975 0 0 0</pose>
          <geometry><box><size>3.8 1.35 1.25</size></box></geometry>
          <material><ambient>0.9 0.18 0.08 1</ambient><diffuse>0.9 0.18 0.08 1</diffuse></material>
        </visual>
        <sensor name="lidar" type="gpu_lidar">
          <pose>2.050 0 1.750 0 0 0</pose>
          <topic>/bus_1/scan</topic>
          <update_rate>10</update_rate>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range><min>0.12</min><max>18.0</max><resolution>0.03</resolution></range>
          </lidar>
          <always_on>1</always_on>
          <visualize>false</visualize>
        </sensor>
      </link>
      <link name="left_wheel">
        <pose>0 0.525 0.220 1.5708 0 0</pose>
        <collision name="collision"><geometry><cylinder><radius>0.22</radius><length>0.16</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.22</radius><length>0.16</length></cylinder></geometry><material><ambient>0.01 0.01 0.01 1</ambient><diffuse>0.01 0.01 0.01 1</diffuse></material></visual>
      </link>
      <link name="right_wheel">
        <pose>0 -0.525 0.220 1.5708 0 0</pose>
        <collision name="collision"><geometry><cylinder><radius>0.22</radius><length>0.16</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.22</radius><length>0.16</length></cylinder></geometry><material><ambient>0.01 0.01 0.01 1</ambient><diffuse>0.01 0.01 0.01 1</diffuse></material></visual>
      </link>
      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
